# Sao chép thành `.env` (cùng cấp `configs/`) — KHÔNG commit `.env`.
#
# Siêu tham số mẫu: `configs/logic_model.yaml` (MCQ) + `configs/fol_model.yaml` (FOL SFT) + mặc định trong code.
# Chỉ thêm dòng dưới đây khi cần ghi đè / bí mật / path máy cụ thể.

# LOGIC_PROJECT_ROOT=/absolute/path/to/Logic_Based_Educational_Queries_Project
# LOGIC_DATA_ROOT=...
# LOGIC_PUSH_TO_HUB=true
# LOGIC_REPO_METHOD=fewshot
# LOGIC_LOG_TEST_EACH_EPOCH=false
# CSV train/dev/test (chung MCQ + FOL), mặc định: .../data/processed/
# LOGIC_SFT_PROCESSED_DIR=.../data/processed
# FOL SFT: FOL_MODEL_NAME, FOL_SFT_PROCESSED_DIR (hoặc dùng chung LOGIC_SFT_PROCESSED_DIR), FOL_PUSH_TO_HUB, …
# FOL_LOAD_IN_8BIT=true  — nạp base ở INT8 8-bit (bitsandbytes), giảm VRAM, chính xác hơn NF4
# FOL_LOAD_IN_4BIT=true  — tên cũ: vẫn bật INT8 8-bit (không còn NF4)
# FOL_GPU_PROFILE=8bit | 4bit | kaggle_p100  — bật INT8 (4bit chỉ còn tên profile, thực tế 8-bit)
